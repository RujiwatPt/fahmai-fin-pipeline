# Core Supabase warehouse
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<anon-or-service-key>
SUPABASE_PASSWORD=<database-password>

# OpenRouter fallback and tool-calling key
OPEN_ROUTER=sk-or-...

# LangSmith tracing
# LANGSMITH_TRACING is set automatically when LANGSMITH_API_KEY is present.
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=fahmai

# SQL analyst / grading database
# Used by fahmai/db.py when the SQL tool should query a separate model-facing DB.
FAHMAI_SQL_DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<database>

# Orchestration LLM
FAHMAI_MODEL=google/gemma-4-31B-it
FAHMAI_LLM_BASE_URL=http://<llm-host>:<port>/v1
FAHMAI_LLM_API_KEY=EMPTY

# Thai small LLM for /agent/thaillm
FAHMAI_THAI_MODEL=typhoon-ai/typhoon-s-thaillm-8b-instruct-research-preview

# Tool-calling specialists
# Blank FAHMAI_TOOL_API_KEY means the code falls back to OPEN_ROUTER.
FAHMAI_TOOL_BASE_URL=https://openrouter.ai/api/v1
FAHMAI_TOOL_API_KEY=
FAHMAI_TOOL_MODEL=google/gemma-4-31b-it

# RAG chunks database and embeddings
RAG_DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<database>
RAG_EMBED_MODEL=BAAI/bge-m3
RAG_EMBED_BASE_URL=http://<embedding-host>:<port>/v1
RAG_EMBED_API_KEY=EMPTY
RAG_EMBED_DIM=1024

# OCR
# OCR base URL and API key inherit FAHMAI_LLM_BASE_URL / FAHMAI_LLM_API_KEY when unset.
# Set FAHMAI_OCR_BASE_URL and FAHMAI_OCR_API_KEY only when OCR runs on a different endpoint.
FAHMAI_OCR_MODEL=typhoon-ocr-preview
FAHMAI_THAI_MODEL=typhoon-ai/typhoon-s-thaillm-8b-instruct-research-preview
